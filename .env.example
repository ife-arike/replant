# Replant — environment variables expected by the React Native app
#
# DO NOT put real values in this file. This file is committed to the public repo.
# To populate real values for local development, run:
#   eas env:pull --environment development
# That command writes a .env.local file (gitignored) with the real values.
#
# Variables prefixed with EXPO_PUBLIC_ are inlined into the app bundle at
# build time and are readable by anyone who downloads the app. Protection
# for these values comes from API-side restrictions (Mapbox URL restrictions,
# Google application restrictions, Supabase Row-Level Security), not secrecy.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_GOOGLE_GEOCODING_KEY=
